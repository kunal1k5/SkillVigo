{
  "info": {
    "_postman_id": "b0c3f6b1-7a6b-4d65-9f2f-0f5f8b8a7c10",
    "name": "SkillVigo API",
    "description": "Postman collection for testing SkillVigo authentication and skill CRUD flow.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Provider Register",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now().toString();",
              "pm.collectionVariables.set('runId', runId);",
              "pm.collectionVariables.set('providerEmail', `provider.${runId}@example.com`);",
              "pm.collectionVariables.set('providerPassword', 'StrongPass123');",
              "pm.collectionVariables.set('providerToken', '');",
              "pm.collectionVariables.set('providerId', '');",
              "pm.collectionVariables.set('skillId', '');"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Response contains token', function () {",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "});",
              "pm.test('Response contains provider user', function () {",
              "  pm.expect(json.user.role).to.eql('provider');",
              "});",
              "pm.collectionVariables.set('providerToken', json.token);",
              "pm.collectionVariables.set('providerId', json.user.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"SkillVigo Provider Test\",\n  \"email\": \"{{providerEmail}}\",\n  \"password\": \"{{providerPassword}}\",\n  \"role\": \"provider\",\n  \"phone\": \"9876543210\",\n  \"location\": \"Kolkata\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "Provider Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Login returns provider token', function () {",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  pm.expect(json.user.role).to.eql('provider');",
              "});",
              "pm.collectionVariables.set('providerToken', json.token);",
              "pm.collectionVariables.set('providerId', json.user.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{providerEmail}}\",\n  \"password\": \"{{providerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Create Skill",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 201', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Skill is created', function () {",
              "  pm.expect(json.skill.id).to.be.a('string').and.not.empty;",
              "  pm.expect(json.skill.provider.id).to.eql(pm.collectionVariables.get('providerId'));",
              "});",
              "pm.collectionVariables.set('skillId', json.skill.id);"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{providerToken}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"MERN Stack Coaching\",\n  \"description\": \"Hands-on coaching for React, Node.js, Express, and MongoDB.\",\n  \"category\": \"Programming\",\n  \"price\": 4999,\n  \"experience\": 4,\n  \"location\": \"Kolkata\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/skills",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "skills"
          ]
        }
      }
    },
    {
      "name": "Get All Skills",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "const json = pm.response.json();",
              "pm.test('Skills list is returned', function () {",
              "  pm.expect(json.skills).to.be.an('array');",
              "  pm.expect(json.count).to.be.at.least(1);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{baseUrl}}/skills",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
